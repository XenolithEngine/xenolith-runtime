#ifndef RUNTIME_INCLUDE_SPRT_CXX_TYPEINDEX_H_
#define RUNTIME_INCLUDE_SPRT_CXX_TYPEINDEX_H_

#include <sprt/cxx/typeinfo>
#include <sprt/cxx/compare>

namespace sprt {

class type_index {
	const type_info *__t_;

public:
	type_index(const type_info &__y) noexcept : __t_(&__y) { }

	bool operator==(const type_index &__y) const noexcept { return *__t_ == *__y.__t_; }

	bool operator<(const type_index &__y) const noexcept { return __t_->before(*__y.__t_); }
	bool operator<=(const type_index &__y) const noexcept { return !__y.__t_->before(*__t_); }
	bool operator>(const type_index &__y) const noexcept { return __y.__t_->before(*__t_); }
	bool operator>=(const type_index &__y) const noexcept { return !__t_->before(*__y.__t_); }
	strong_ordering operator<=>(const type_index &__y) const noexcept {
		if (*__t_ == *__y.__t_) {
			return strong_ordering::equal;
		}
		if (__t_->before(*__y.__t_)) {
			return strong_ordering::less;
		}
		return strong_ordering::greater;
	}

	size_t hash_code() const noexcept { return __t_->hash_code(); }
	const char *name() const noexcept { return __t_->name(); }
};

template <class _Tp>
struct hash;

template <>
struct hash<type_index> {
	size_t operator()(type_index __index) const noexcept { return __index.hash_code(); }
};

} // namespace sprt

#endif
