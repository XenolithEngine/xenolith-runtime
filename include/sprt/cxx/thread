#ifndef RUNTIME_INCLUDE_SPRT_CXX_THREAD_H_
#define RUNTIME_INCLUDE_SPRT_CXX_THREAD_H_

#include <sprt/cxx/compare>
#include <sprt/cxx/function>
#include <sprt/cxx/detail/ctypes.h>
#include <sprt/cxx/__type_traits/modifications.h>
#include <sprt/c/cross/__sprt_sysid.h>
#include <sprt/c/__sprt_pthread.h>
#include <sprt/c/sys/__sprt_sprt.h>

namespace sprt {

using timeout_t = __sprt_sprt_timeout_t;

class thread {
public:
	// class thread::id
	struct id;

	using native_handle_type = __sprt_pthread_t;

	~thread();

	thread() noexcept { }

	template <typename F, typename... Args,
			enable_if_t<!is_same<remove_cvref_t<F>, thread>::value, int> = 0>
	explicit thread(F &&f, Args &&...args) {
		__makeThread([f = sprt::forward<F>(f), ... args = sprt::forward<Args>(args)]() mutable {
			sprt::__invoke(f, sprt::forward<Args>(args)...);
		});
	}

	thread(const thread &) = delete;
	thread &operator=(const thread &) = delete;

	thread(thread &&) noexcept;
	thread &operator=(thread &&) noexcept;

	// members
	void swap(thread &other) noexcept { sprt::swap(__native, other.__native); }

	bool joinable() const noexcept;

	// Returns true if thread is successfully joined
	bool try_join();

	void join();
	void detach();

	// Note that after successful join or detach it should return id{0};
	id get_id() const noexcept;

	native_handle_type native_handle() noexcept { return __native; }

	static unsigned int hardware_concurrency() noexcept;

protected:
	int __makeThread(__malloc_function<void()> &&);

	native_handle_type __native = nullptr;
};

struct thread::id {
	using __type = __sprt_pid_t;

	__type __native = 0;
};

constexpr inline bool operator==(thread::id x, thread::id y) noexcept {
	return x.__native == y.__native;
}
constexpr inline auto operator<=>(thread::id x, thread::id y) noexcept {
	return x.__native <=> y.__native;
}

// hash support
template <class T>
struct hash;

template <>
struct hash<thread::id> {
	constexpr size_t operator()(const thread::id &value) const noexcept {
		return static_cast<size_t>(value.__native);
	}
};

// namespace this_thread
namespace this_thread {
thread::id get_id() noexcept;

void yield() noexcept;

void sleep_for(const timeout_t &rel_time);
} // namespace this_thread

} // namespace sprt

#endif // RUNTIME_INCLUDE_SPRT_CXX_THREAD_H_
