#ifndef RUNTIME_INCLUDE_SPRT_CXX_TYPE_TRAITS_
#define RUNTIME_INCLUDE_SPRT_CXX_TYPE_TRAITS_

#include <sprt/cxx/__type_traits/constants.h>
#include <sprt/cxx/__type_traits/modifications.h>
#include <sprt/cxx/__type_traits/operations.h>
#include <sprt/cxx/__type_traits/queries.h>
#include <sprt/cxx/__type_traits/types.h>
#include <sprt/cxx/__type_traits/unwrap_ref.h>

#include <sprt/cxx/__functional/invoke.h>
#include <sprt/cxx/__utility/swap.h>

namespace sprt {

template <typename...>
struct conjunction : true_type { };

template <typename _Arg>
struct conjunction<_Arg> : _Arg { };

template <typename _Arg, typename... _Args>
struct conjunction<_Arg, _Args...>
: conditional_t<!bool(_Arg::value), _Arg, conjunction<_Args...>> { };

template <typename... _Args>
inline constexpr bool conjunction_v = conjunction<_Args...>::value;


template <typename...>
struct disjunction : sprt::false_type { };

template <typename B1>
struct disjunction<B1> : B1 { };

template <typename B1, typename... Bn>
struct disjunction<B1, Bn...> : sprt::conditional_t<bool(B1::value), B1, disjunction<Bn...>> { };

template <typename... _Args>
inline constexpr bool disjunction_v = disjunction<_Args...>::value;


template <typename B>
struct negation : sprt::bool_constant<!bool(B::value)> { };

template <typename B>
inline constexpr bool negation_v = negation<B>::value;


SPRT_LOCAL inline constexpr bool is_constant_evaluated() noexcept {
	return __builtin_is_constant_evaluated();
}

} // namespace sprt

#endif // RUNTIME_INCLUDE_SPRT_CXX_TYPE_TRAITS_
