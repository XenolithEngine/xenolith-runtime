SPRT_API void cleanup_register(pool_t *p, __pool_function<void()> &&cb);

SPRT_API void pre_cleanup_register(pool_t *p, __pool_function<void()> &&cb);

} // namespace sprt::memory::pool

#endif // RUNTIME_INCLUDE_SPRT_CXX_FUNCTION_H_
