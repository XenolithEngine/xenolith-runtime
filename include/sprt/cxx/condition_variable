#ifndef RUNTIME_INCLUDE_SPRT_CXX_CONDITION_VARIABLE_H_
#define RUNTIME_INCLUDE_SPRT_CXX_CONDITION_VARIABLE_H_

#include <sprt/runtime/thread/qcondvar.h>
#include <sprt/cxx/mutex>

namespace sprt {

enum class cv_status {
	no_timeout,
	timeout
};

class condition_variable {
public:
	using native_handle_type = __qcondvar_data;
	using timeout_type = __sprt_sprt_timeout_t;

	condition_variable() { }
	~condition_variable() { notify_all(); }

	condition_variable(const condition_variable &) = delete;
	condition_variable &operator=(const condition_variable &) = delete;

	void notify_one() noexcept { qcondvar_base::_signal<__sprt_sprt_qlock_wake_one>(&data, 0); }
	void notify_all() noexcept { qcondvar_base::_signal<__sprt_sprt_qlock_wake_all>(&data, 0); }

	void wait(unique_lock<mutex> &lock) {
		qcondvar_base::_wait<__sprt_sprt_qlock_wait, nullptr, __cond_mutex_id, __cond_mutex_lock,
				__cond_mutex_unlock>(&data, &lock, nullptr, 0);
	}

	template <typename Pred>
	void wait(unique_lock<mutex> &lock, Pred pred) {
		while (!pred()) { wait(lock); }
	}

	cv_status wait_for(unique_lock<mutex> &lock, timeout_type *ns_timeout) {
		auto st =
				qcondvar_base::_wait<__sprt_sprt_qlock_wait, __sprt_sprt_qlock_now, __cond_mutex_id,
						__cond_mutex_lock, __cond_mutex_unlock>(&data, &lock, ns_timeout, 0);
		if (st == Status::Timeout) {
			return cv_status::timeout;
		}
		return cv_status::no_timeout;
	}

	cv_status wait_for(unique_lock<mutex> &lock, timeout_type ns_timeout) {
		return wait_for(lock, &ns_timeout);
	}

	template <typename Pred>
	bool wait_for(unique_lock<mutex> &lock, timeout_type ns_timeout, Pred pred) {
		while (!pred()) {
			if (wait_for(lock, &ns_timeout) == cv_status::timeout) {
				return pred();
			}
		}
		return true;
	}

	native_handle_type native_handle() const noexcept { return data; }

protected:
	static uint64_t __cond_mutex_id(void *mtx) {
		auto ulock = reinterpret_cast<unique_lock<mutex> *>(mtx);
		return static_cast<uint64_t>(reinterpret_cast<uintptr_t>(ulock->mutex()));
	}

	static Status __cond_mutex_lock(void *mtx) {
		auto ulock = reinterpret_cast<unique_lock<mutex> *>(mtx);
		ulock->lock();
		return Status::Ok;
	}

	static Status __cond_mutex_unlock(void *mtx) {
		auto ulock = reinterpret_cast<unique_lock<mutex> *>(mtx);
		ulock->unlock();
		return Status::Ok;
	}

	native_handle_type data;
};

class condition_variable_any {
public:
	using timeout_type = __sprt_sprt_timeout_t;

	condition_variable_any() { }
	~condition_variable_any() { notify_all(); }

	condition_variable_any(const condition_variable_any &) = delete;
	condition_variable_any &operator=(const condition_variable_any &) = delete;

	void notify_one() noexcept {
		{ lock_guard<mutex> __lx(_mtx); }
		_cv.notify_one();
	}
	void notify_all() noexcept {
		{ lock_guard<mutex> __lx(_mtx); }
		_cv.notify_all();
	}

	// noninterruptible waits
	template <typename Lock>
	void wait(Lock &lock) {
		unique_lock<mutex> __lk(_mtx);
		lock.unlock();
		lock_guard<unique_lock<mutex> > __lx(__lk, adopt_lock_t());
		_cv.wait(__lk);
		lock.lock();
	}

	template <typename Lock, typename Pred>
	void wait(Lock &lock, Pred pred) {
		while (!pred()) { wait(lock); }
	}

	template <typename Lock>
	cv_status wait_for(Lock &lock, timeout_type *ns_timeout) {
		unique_lock<mutex> __lk(_mtx);
		lock.unlock();
		lock_guard<unique_lock<mutex> > __lx(__lk, adopt_lock_t());
		auto ret = _cv.wait_for(__lk, ns_timeout);
		lock.lock();
		return ret;
	}

	template <typename Lock>
	cv_status wait_for(Lock &lock, timeout_type ns_timeout) {
		return wait_for(lock, &ns_timeout);
	}

	template <typename Lock, typename Pred>
	bool wait_for(Lock &lock, timeout_type ns_timeout, Pred pred) {
		while (!pred()) {
			if (wait_for(lock, &ns_timeout) == cv_status::timeout) {
				return pred();
			}
		}
		return true;
	}

protected:
	condition_variable _cv;
	mutex _mtx;
};

} // namespace sprt

#endif
