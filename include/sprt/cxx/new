[[nodiscard]]
inline void *operator new(sprt::size_t size, sprt::nothrow_t) noexcept {
	if (size == 0) {
		size = 1;
	}
	return __sprt_malloc(size);
}

[[nodiscard]]
inline void *operator new[](sprt::size_t size, sprt::nothrow_t) noexcept {
	if (size == 0) {
		size = 1;
	}
	return __sprt_malloc(size);
}

[[nodiscard]]
inline void *operator new(sprt::size_t size, sprt::align_val_t al, sprt::nothrow_t) noexcept {
	if (size == 0) {
		size = 1;
	}
	if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
		return __sprt_malloc(size);
	} else {
		return __sprt_aligned_alloc(sprt::to_underlying(al), size);
	}
}

[[nodiscard]]
inline void *operator new[](sprt::size_t size, sprt::align_val_t al, sprt::nothrow_t) noexcept {
	if (size == 0) {
		size = 1;
	}
	if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
		return __sprt_malloc(size);
	} else {
		return __sprt_aligned_alloc(sprt::to_underlying(al), size);
	}
}

inline void operator delete(void *ptr, sprt::align_val_t al) noexcept {
	if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
		__sprt_free(ptr);
	} else {
		__sprt_aligned_free(ptr);
	}
}
inline void operator delete[](void *ptr, sprt::align_val_t al) noexcept {
	if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
		__sprt_free(ptr);
	} else {
		__sprt_aligned_free(ptr);
	}
}

inline void operator delete(void *ptr, sprt::align_val_t al, const sprt::nothrow_t &) noexcept {
	if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
		__sprt_free(ptr);
	} else {
		__sprt_aligned_free(ptr);
	}
}
inline void operator delete[](void *ptr, sprt::align_val_t al, const sprt::nothrow_t &) noexcept {
	if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
		__sprt_free(ptr);
	} else {
		__sprt_aligned_free(ptr);
	}
}

[[nodiscard]]
inline constexpr void *operator new(sprt::size_t size, void *ptr, sprt::nothrow_t) noexcept {
	return ptr;
}

[[nodiscard]]
inline constexpr void *operator new[](sprt::size_t size, void *ptr, sprt::nothrow_t) noexcept {
	return ptr;
}

namespace sprt {

struct SPRT_API AllocPlacement {
	static constexpr void *operator new(size_t size, void *ptr) noexcept { return ptr; }
	static constexpr void *operator new[](size_t size, void *ptr) noexcept { return ptr; }

	static constexpr void operator delete(void *, void *) noexcept { }
	static constexpr void operator delete[](void *, void *) noexcept { }
};

struct SPRT_API AllocBase : public AllocPlacement {
	static void *operator new(size_t size) { return __sprt_malloc(size); }
	static void *operator new[](size_t size) { return __sprt_malloc(size); }

	static void *operator new(size_t size, const sprt::nothrow_t &tag) noexcept {
		return __sprt_malloc(size);
	}

	static void *operator new[](size_t size, const sprt::nothrow_t &tag) noexcept {
		return __sprt_malloc(size);
	}

	static void *operator new(size_t size, sprt::align_val_t al,
			const sprt::nothrow_t &tag) noexcept {
		if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
			return __sprt_malloc(size);
		} else {
			return __sprt_aligned_alloc(sprt::to_underlying(al), size);
		}
	}

	static void *operator new[](size_t size, sprt::align_val_t al,
			const sprt::nothrow_t &tag) noexcept {
		if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
			return __sprt_malloc(size);
		} else {
			return __sprt_aligned_alloc(sprt::to_underlying(al), size);
		}
	}

	// Allocation from pool is forbidden for common classes
	static void *operator new(size_t size, memory::pool_t *ptr) noexcept = delete;
	static void *operator new[](size_t size, memory::pool_t *ptr) noexcept = delete;

	static void operator delete(void *ptr) noexcept {
		__sprt_free(ptr); //
	}
	static void operator delete[](void *ptr) noexcept {
		__sprt_free(ptr); //
	}
	static void operator delete(void *ptr, sprt::align_val_t al) noexcept {
		if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
			__sprt_free(ptr);
		} else {
			__sprt_aligned_free(ptr);
		}
	}
	static void operator delete[](void *ptr, sprt::align_val_t al) noexcept {
		if (sprt::to_underlying(al) <= alignof(__sprt_max_align_t)) {
			__sprt_free(ptr);
		} else {
			__sprt_aligned_free(ptr);
		}
	}

	static constexpr void *operator new(sprt::size_t size, void *ptr, sprt::nothrow_t) noexcept {
		return ptr;
	}

	static constexpr void *operator new[](sprt::size_t size, void *ptr, sprt::nothrow_t) noexcept {
		return ptr;
	}

	constexpr void operator delete(void *, void *) noexcept { }
	constexpr void operator delete[](void *, void *) noexcept { }
};

