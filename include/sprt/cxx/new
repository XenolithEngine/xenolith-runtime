namespace std {

// Just to use with constexpr allocations
template <typename _Tp>
class allocator {
public:
	using size_type = sprt::size_t;
	using difference_type = sprt::ptrdiff_t;
	using value_type = _Tp;

	constexpr allocator() noexcept { }

	template <typename _Up>
	constexpr allocator(const allocator<_Up> &) noexcept { }

	[[nodiscard]]
	constexpr _Tp *allocate(size_type __n) {
		static_assert(sizeof(_Tp) >= 0, "cannot allocate memory for an incomplete type");
		return static_cast<_Tp *>(::operator new(__n * sizeof(_Tp)));
	}

	constexpr void deallocate(_Tp *__p, size_type __n) noexcept { ::operator delete(__p); }
};

} // namespace std

