namespace sprt {

struct nothrow_t {
	explicit nothrow_t() = default;
};

extern const nothrow_t nothrow;

enum class align_val_t : sprt::size_t {
};

} // namespace sprt

namespace sprt::memory {

class OpaquePool;
class OpaqueAllocator;

using pool_t = OpaquePool;
using allocator_t = OpaqueAllocator;

template <typename T>
constexpr T *allocate() {
	if (__builtin_is_constant_evaluated()) {
		return std::allocator<T>().allocate(1);
	} else {
		if constexpr (alignof(T) <= alignof(__sprt_max_align_t)) {
			return reinterpret_cast<T *>(__sprt_malloc(sizeof(T)));
		} else {
			return reinterpret_cast<T *>(__sprt_aligned_alloc(alignof(T), sizeof(T)));
		}
	}
}

template <typename T>
constexpr T *allocate(size_t n) {
	if (__builtin_is_constant_evaluated()) {
		return std::allocator<T>().allocate(n);
	} else {
		if constexpr (alignof(T) <= alignof(__sprt_max_align_t)) {
			return reinterpret_cast<T *>(__sprt_malloc(sizeof(T) * n));
		} else {
			return reinterpret_cast<T *>(__sprt_aligned_alloc(alignof(T), sizeof(T) * n));
		}
	}
}

template <typename T>
constexpr void deallocate(T *t) {
	if (__builtin_is_constant_evaluated()) {
		return std::allocator<T>().deallocate(t, 1);
	} else {
		if constexpr (alignof(T) <= alignof(__sprt_max_align_t)) {
			__sprt_free(t);
		} else {
			__sprt_aligned_free(t);
		}
	}
}

template <typename T>
constexpr void deallocate(T *t, size_t n) {
	if (__builtin_is_constant_evaluated()) {
		return std::allocator<T>().deallocate(t, n);
	} else {
		if constexpr (alignof(T) <= alignof(__sprt_max_align_t)) {
			__sprt_free(t);
		} else {
			__sprt_aligned_free(t);
		}
	}
}

} // namespace sprt::memory

