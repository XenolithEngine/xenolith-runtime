#ifndef RUNTIME_INCLUDE_SPRT_CXX_MUTEX_H_
#define RUNTIME_INCLUDE_SPRT_CXX_MUTEX_H_

#include <sprt/c/__sprt_pthread.h>
#include <sprt/cxx/__mutex/unique_lock.h>
#include <sprt/cxx/__mutex/lock_guard.h>
#include <sprt/cxx/__mutex/timed_mutex.h>
#include <sprt/cxx/__mutex/recursive_timed_mutex.h>
#include <sprt/runtime/thread/qmutex.h>
#include <sprt/runtime/thread/qonce.h>
#include <sprt/runtime/thread/rmutex.h>

namespace sprt {

// Just use qmutex as common std::mutex
using mutex = qmutex;

using recursive_mutex = rmutex;

using once_flag = sprt::qonce;

template < typename Callable, typename... Args >
void call_once(sprt::once_flag &flag, Callable &&f, Args &&...args) {
	flag([f = sprt::forward<Callable>(f), ... args = sprt::forward<Args>(args)]() mutable {
		sprt::__invoke(f, sprt::forward<Args>(args)...);
	});
}

} // namespace sprt

#endif // RUNTIME_INCLUDE_SPRT_CXX_MUTEX_H_
