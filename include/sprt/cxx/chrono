#ifndef RUNTIME_INCLUDE_SPRT_CXX_CHRONO_
#define RUNTIME_INCLUDE_SPRT_CXX_CHRONO_

#include <sprt/c/__sprt_time.h>
#include <sprt/c/sys/__sprt_sprt.h>

// lightweight chrono-like implementation

namespace sprt {

template <__sprt_sprt_timeout_t SecondsTick, __sprt_sprt_timeout_t NanosInTick = 1'000'000'000>
struct ratio {
	constexpr __sprt_sprt_timeout_t operator()(__sprt_sprt_timeout_t t) {
		return t * SecondsTick * NanosInTick;
	}
};

using nano = ratio<1, 1>;
using micro = ratio<1, 1'000>;
using milli = ratio<1, 1'000'000>;

} // namespace sprt

namespace sprt::chrono {

template <typename Rep, typename Period = sprt::ratio<1>>
struct duration {
	operator __sprt_sprt_timeout_t() const {
		return Period()(static_cast<__sprt_sprt_timeout_t>(value));
	}

	Rep value = 0;
};

using nanoseconds = duration<__sprt_sprt_timeout_t, sprt::nano>;
using microseconds = duration<__sprt_sprt_timeout_t, sprt::micro>;
using milliseconds = duration<__sprt_sprt_timeout_t, sprt::milli>;
using seconds = duration<__sprt_sprt_timeout_t>;
using minutes = duration<__sprt_sprt_timeout_t, sprt::ratio<60>>;
using hours = duration<__sprt_sprt_timeout_t, sprt::ratio<3'600>>;
using days = duration<__sprt_sprt_timeout_t, sprt::ratio<86'400>>;
using weeks = duration<__sprt_sprt_timeout_t, sprt::ratio<604'800>>;
using months = duration<__sprt_sprt_timeout_t, sprt::ratio<2'629'746>>;
using years = duration<__sprt_sprt_timeout_t, sprt::ratio<31'556'952>>;

} // namespace sprt::chrono

#endif // RUNTIME_INCLUDE_SPRT_CXX_CHRONO_
