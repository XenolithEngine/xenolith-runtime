#ifndef RUNTIME_INCLUDE_SPRT_CXX_CSTDLIB_H_
#define RUNTIME_INCLUDE_SPRT_CXX_CSTDLIB_H_

#include <sprt/runtime/init.h>
#include <sprt/runtime/unicode.h>
#include <sprt/c/__sprt_stdlib.h>

namespace sprt {

// start and termination
[[noreturn]]
SPRT_FORCEINLINE void abort() noexcept {
	__sprt_abort();
}
SPRT_FORCEINLINE int atexit(void (*fn)(void)) noexcept { return __sprt_atexit(fn); }
SPRT_FORCEINLINE int at_quick_exit(void (*fn)(void)) noexcept { return __sprt_at_quick_exit(fn); }

[[noreturn]]
SPRT_FORCEINLINE void exit(int status) {
	__sprt_exit(status);
}

[[noreturn]]
SPRT_FORCEINLINE void _Exit(int status) noexcept {
	__sprt__Exit(status);
}

[[noreturn]]
SPRT_FORCEINLINE void quick_exit(int status) noexcept {
	__sprt_quick_exit(status);
}

SPRT_FORCEINLINE char *getenv(const char *name) { return __sprt_getenv(name); }
SPRT_FORCEINLINE int system(const char *string) { return __sprt_system(string); }

// C library memory allocation
SPRT_FORCEINLINE void *aligned_alloc(size_t alignment, size_t size) {
	return __sprt_aligned_alloc(alignment, size);
}
SPRT_FORCEINLINE void aligned_free(void *ptr) { __sprt_aligned_free(ptr); }
SPRT_FORCEINLINE void *calloc(size_t nmemb, size_t size) { return __sprt_calloc(nmemb, size); }
SPRT_FORCEINLINE void free(void *ptr) { return __sprt_free(ptr); }
SPRT_FORCEINLINE void *malloc(size_t size) { return __sprt_malloc(size); }
SPRT_FORCEINLINE void *realloc(void *ptr, size_t size) { return __sprt_realloc(ptr, size); }

SPRT_FORCEINLINE double atof(const char *nptr) { return __sprt_atof(nptr); }
SPRT_FORCEINLINE int atoi(const char *nptr) { return __sprt_atoi(nptr); }
SPRT_FORCEINLINE long int atol(const char *nptr) { return __sprt_atol(nptr); }
SPRT_FORCEINLINE long long int atoll(const char *nptr) { return __sprt_atoll(nptr); }
SPRT_FORCEINLINE double strtod(const char *nptr, char **endptr) {
	return __sprt_strtod(nptr, endptr);
}
SPRT_FORCEINLINE float strtof(const char *nptr, char **endptr) {
	return __sprt_strtof(nptr, endptr);
}
SPRT_FORCEINLINE long double strtold(const char *nptr, char **endptr) {
	return __sprt_strtold(nptr, endptr);
}
SPRT_FORCEINLINE long int strtol(const char *nptr, char **endptr, int base) {
	return __sprt_strtol(nptr, endptr, base);
}
SPRT_FORCEINLINE long long int strtoll(const char *nptr, char **endptr, int base) {
	return __sprt_strtoll(nptr, endptr, base);
}
SPRT_FORCEINLINE unsigned long int strtoul(const char *nptr, char **endptr, int base) {
	return __sprt_strtoul(nptr, endptr, base);
}
SPRT_FORCEINLINE unsigned long long int strtoull(const char *nptr, char **endptr, int base) {
	return __sprt_strtoull(nptr, endptr, base);
}

