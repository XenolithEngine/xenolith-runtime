#ifndef RUNTIME_INCLUDE_SPRT_CXX_FORWARD_LIST_H_
#define RUNTIME_INCLUDE_SPRT_CXX_FORWARD_LIST_H_

#include <sprt/cxx/__memory/allocator_traits.h>
#include <sprt/cxx/detail/allocator_malloc.h>
#include <sprt/cxx/detail/allocator_pool.h>
#include <sprt/cxx/__list/forward_list_base.h>
#include <sprt/cxx/initializer_list>
#include <sprt/cxx/algorithm>

namespace sprt {

template <typename T, typename Allocator>
class SPRT_API __forward_list : public Allocator::base_class {
public:
	using value_type = T;
	using allocator_type = Allocator;
	using size_type = size_t;
	using difference_type = ptrdiff_t;
	using reference = value_type &;
	using const_reference = const value_type &;
	using pointer = typename allocator_type::pointer;
	using const_pointer = typename allocator_type::const_pointer;

	using node_type = detail::ForwardListNode<value_type, Allocator>;
	using base_type = detail::forward_list_base<value_type, allocator_type>;

	using iterator = detail::ForwardListIterator<value_type, Allocator>;
	using const_iterator = detail::ForwardListConstIterator<value_type, Allocator>;

	constexpr __forward_list() noexcept : __forward_list(allocator_type()) { }

	constexpr explicit __forward_list(const allocator_type &alloc) noexcept : _base(alloc) { }

	constexpr explicit __forward_list(size_type count,
			const allocator_type &alloc = allocator_type()) noexcept;

	constexpr __forward_list(size_type count, const value_type &value,
			const allocator_type &alloc = allocator_type()) noexcept;

	template <typename InputIt, enable_if_t<__has_input_iterator_category<InputIt>::value, int> = 0>
	constexpr __forward_list(InputIt first, InputIt last,
			const allocator_type &alloc = allocator_type()) noexcept;

	constexpr __forward_list(const __forward_list &other) noexcept;
	constexpr __forward_list(__forward_list &&other) noexcept;

	constexpr __forward_list(const __forward_list &other,
			const type_identity_t<allocator_type> &alloc) noexcept;
	constexpr __forward_list(__forward_list &&other,
			const type_identity_t<allocator_type> &alloc) noexcept;

	constexpr __forward_list(initializer_list<T> init,
			const allocator_type &alloc = allocator_type()) noexcept;

	constexpr ~__forward_list() noexcept;

	constexpr __forward_list &operator=(const __forward_list &other) noexcept;
	constexpr __forward_list &operator=(__forward_list &&other) noexcept;
	constexpr __forward_list &operator=(initializer_list<value_type> ilist) noexcept;

	constexpr void assign(size_type count, const T &value) noexcept;

	template <typename InputIt, enable_if_t<__has_input_iterator_category<InputIt>::value, int> = 0>
	constexpr void assign(InputIt first, InputIt last) noexcept;
	constexpr void assign(initializer_list<T> ilist) noexcept;

	constexpr allocator_type get_allocator() const noexcept { return _base.get_allocator(); }

	constexpr reference front() noexcept {
		return static_cast<node_type *>(_base.front())->value.ref();
	}
	constexpr const_reference front() const noexcept {
		return static_cast<node_type *>(_base.front())->value.ref();
	}

	constexpr iterator before_begin() noexcept { return iterator(_base.end()); }
	constexpr const_iterator before_begin() const noexcept { return const_iterator(_base.end()); }
	constexpr const_iterator cbefore_begin() const noexcept { return const_iterator(_base.end()); }

	constexpr iterator begin() noexcept { return iterator(_base.front()); }
	constexpr const_iterator begin() const noexcept { return const_iterator(_base.front()); }
	constexpr const_iterator cbegin() const noexcept { return const_iterator(_base.front()); }

	constexpr iterator end() noexcept { return iterator(_base.end()); }
	constexpr const_iterator end() const noexcept { return const_iterator(_base.end()); }
	constexpr const_iterator cend() const noexcept { return const_iterator(_base.end()); }

	constexpr bool empty() const noexcept { return _base.front() == _base.end(); }
	constexpr size_type max_size() const noexcept { return _base.max_size(); }
	constexpr size_type size() const noexcept { return _base.size(); }

	constexpr void swap(__forward_list &) noexcept;
	constexpr void clear() noexcept { _base.clear(); }

	template < typename... Args >
	constexpr reference emplace_front(Args &&...args) noexcept;

	constexpr reference push_front(const T &value) noexcept;
	constexpr reference push_front(T &&value) noexcept;

	constexpr iterator insert_after(const_iterator pos, const T &value) noexcept;
	constexpr iterator insert_after(const_iterator pos, T &&value) noexcept;
	constexpr iterator insert_after(const_iterator pos, size_type count, const T &value) noexcept;

	template <typename InputIt, enable_if_t<__has_input_iterator_category<InputIt>::value, int> = 0>
	constexpr iterator insert_after(const_iterator pos, InputIt first, InputIt last) noexcept;
	constexpr iterator insert_after(const_iterator pos, initializer_list<T> ilist) noexcept;

	template < typename... Args >
	constexpr iterator emplace_after(const_iterator pos, Args &&...args) noexcept;

	constexpr iterator erase_after(const_iterator pos) noexcept;
	constexpr iterator erase_after(const_iterator first, const_iterator last) noexcept;

	constexpr void pop_front() noexcept;

	constexpr void resize(size_type count) noexcept;
	constexpr void resize(size_type count, const value_type &value) noexcept;

	constexpr void memory_persistent(bool value) noexcept { _base.memory_persistent(value); }
	constexpr bool memory_persistent() const noexcept { return _base.memory_persistent(); }

	constexpr void reserve(size_type size) { _base.reserve(size); }
	constexpr size_type capacity() const { return _base.capacity(); }

	constexpr void shrink_to_fit() { _base.shrink_to_fit(); }
	void clear_deallocate() { return _base.clear_deallocate(); }

protected:
	base_type _base;
};

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(size_type count,
		const allocator_type &alloc) noexcept
: __forward_list(alloc) {
	_base.expand_front(count,
			[](const base_type::node_allocator_type &nalloc, node_type *node) SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc)); //
	});
}

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(size_type count,
		const value_type &value, const allocator_type &alloc) noexcept
: __forward_list(alloc) {
	_base.expand_front(count,
			[value = &value](const base_type::node_allocator_type &nalloc, node_type *node)
					SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc), *value); //
	});
}

template <typename T, typename Allocator>
template <typename InputIt, enable_if_t<__has_input_iterator_category<InputIt>::value, int>>
constexpr inline __forward_list<T, Allocator>::__forward_list(InputIt first, InputIt last,
		const allocator_type &alloc) noexcept
: __forward_list(alloc) {
	// TODO: we can optimize insertion with _base.expand when std::distance for iterators is constant-time
	auto iter = before_begin();
	while (first != last) {
		iter = emplace_after(iter, *first);
		++first;
	}
}


template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(const __forward_list &other) noexcept
: _base(other._base,
		  sprt::allocator_traits<Allocator>::select_on_container_copy_construction(
				  other.get_allocator())) { }

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(__forward_list &&other) noexcept
: _base(sprt::move_unsafe(other), other.get_allocator()) { }

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(const __forward_list &other,
		const type_identity_t<allocator_type> &alloc) noexcept
: _base(other._base, alloc) { }

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(__forward_list &&other,
		const type_identity_t<allocator_type> &alloc) noexcept
: _base(sprt::move_unsafe(other), alloc) { }

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::__forward_list(initializer_list<T> init,
		const allocator_type &alloc) noexcept
: __forward_list(alloc) {
	auto source = init.begin();
	_base.expand_front(init.size(),
			[&](const base_type::node_allocator_type &nalloc, node_type *node) SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc), *source++); //
	});
}

template <typename T, typename Allocator>
constexpr inline __forward_list<T, Allocator>::~__forward_list() noexcept { }

template <typename T, typename Allocator>
constexpr inline auto __forward_list<T, Allocator>::operator=(const __forward_list &other) noexcept
		-> __forward_list & {
	using traits = sprt::allocator_traits<allocator_type>;

	if constexpr (traits::propagate_on_container_copy_assignment::value) {
		_base.set_allocator(other.get_allocator());
	}

	_base = other._base;
	return *this;
}

template <typename T, typename Allocator>
constexpr inline auto __forward_list<T, Allocator>::operator=(__forward_list &&other) noexcept
		-> __forward_list & {
	using traits = sprt::allocator_traits<allocator_type>;

	if constexpr (traits::propagate_on_container_move_assignment::value) {
		_base.set_allocator(other.get_allocator());
	}

	_base = sprt::move_unsafe(other._base);
	return *this;
}


template <typename T, typename Allocator>
constexpr inline auto __forward_list<T, Allocator>::operator=(
		initializer_list<value_type> init) noexcept -> __forward_list & {
	assign(init);
	return *this;
}

template <typename T, typename Allocator>
constexpr inline void __forward_list<T, Allocator>::assign(size_type count,
		const T &value) noexcept {
	auto preallocTmp = _base.memory_persistent();
	_base.memory_persistent(true);
	_base.clear();
	_base.memory_persistent(preallocTmp);

	_base.expand_front(count,
			[value = &value](const base_type::node_allocator_type &nalloc, node_type *node)
					SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc), *value); //
	});
}

template <typename T, typename Allocator>
template <typename InputIt, enable_if_t<__has_input_iterator_category<InputIt>::value, int>>
constexpr inline void __forward_list<T, Allocator>::assign(InputIt first, InputIt last) noexcept {
	auto preallocTmp = _base.memory_persistent();
	_base.memory_persistent(true);
	_base.clear();
	_base.memory_persistent(preallocTmp);

	auto iter = before_begin();
	while (first != last) {
		iter = emplace_after(iter, *first);
		++first;
	}
}

template <typename T, typename Allocator>
constexpr inline void __forward_list<T, Allocator>::assign(initializer_list<T> init) noexcept {
	auto preallocTmp = _base.memory_persistent();
	_base.memory_persistent(true);
	_base.clear();
	_base.memory_persistent(preallocTmp);

	auto source = init.begin();
	_base.expand_front(init.size(),
			[&](const base_type::node_allocator_type &nalloc, node_type *node) SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc), *source++); //
	});
}

template <typename T, typename Allocator>
template < typename... Args >
constexpr __forward_list<T, Allocator>::reference __forward_list<T, Allocator>::emplace_front(
		Args &&...args) noexcept {
	auto node = _base.allocate_node();
	node->value.construct(get_allocator(), sprt::forward<Args>(args)...);
	_base.insert_front(node);
	return node->value.ref();
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::reference __forward_list<T, Allocator>::push_front(
		const T &value) noexcept {
	return emplace_front(value);
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::reference __forward_list<T, Allocator>::push_front(
		T &&value) noexcept {
	return emplace_front(sprt::move_unsafe(value));
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::insert_after(
		const_iterator pos, const T &value) noexcept {
	auto node = _base.allocate_node();
	node->value.construct(get_allocator(), value);
	_base.insert(const_cast<base_type::basic_node_type *>(pos.__target), node);
	return iterator(node);
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::insert_after(
		const_iterator pos, T &&value) noexcept {
	auto node = _base.allocate_node();
	node->value.construct(get_allocator(), sprt::move_unsafe(value));
	_base.insert(const_cast<base_type::basic_node_type *>(pos.__target), node);
	return iterator(node);
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::insert_after(
		const_iterator pos, size_type count, const T &value) noexcept {
	auto node = _base.expand(pos.__target, count,
			[value = &value](const base_type::node_allocator_type &nalloc, node_type *node)
					SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc), *value); //
	});
	return iterator(node);
}

template <typename T, typename Allocator>
template <typename InputIt, enable_if_t<__has_input_iterator_category<InputIt>::value, int>>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::insert_after(
		const_iterator iter, InputIt first, InputIt last) noexcept {
	while (first != last) {
		iter = emplace_after(iter, *first);
		++first;
	}
	return iter;
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::insert_after(
		const_iterator pos, initializer_list<T> init) noexcept {
	auto source = init.begin();
	auto node = _base.expand_front(init.size(),
			[&](const base_type::node_allocator_type &nalloc, node_type *node) SPRT_LAMBDAINLINE {
		node->value.construct(allocator_type(nalloc), *source++); //
	});
	return iterator(node);
}

template <typename T, typename Allocator>
template < typename... Args >
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::emplace_after(
		const_iterator pos, Args &&...args) noexcept {
	auto node = _base.allocate_node();
	node->value.construct(get_allocator(), sprt::forward<Args>(args)...); //
	_base.insert(const_cast<node_type **>(pos.__target), node);
	return iterator(node);
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::erase_after(
		const_iterator pos) noexcept {
	auto node = _base.erase_after(const_cast<base_type::basic_node_type *>(pos.__target));
	return iterator(node);
}

template <typename T, typename Allocator>
constexpr __forward_list<T, Allocator>::iterator __forward_list<T, Allocator>::erase_after(
		const_iterator first, const_iterator last) noexcept {
	while (first != last) {
		first = (_base.erase_after(const_cast<base_type::basic_node_type *>(first.__target)));
	}
	return first;
}

template <typename T, typename Allocator>
constexpr void __forward_list<T, Allocator>::pop_front() noexcept {
	_base.erase_after(before_begin().__target);
}

template <typename T, typename Allocator>
constexpr void __forward_list<T, Allocator>::resize(size_type count) noexcept {
	auto target = before_begin();
	if (_base.size() > count) {
		while (count > 0) {
			++target;
			--count;
		}

		while (target != end()) { target = iterator(_base.erase_after(target.__target)); }
	} else if (_base.size() < count) {
		while (target.__target->next != _base.end()) { ++target; }

		_base.expand(target.__target, count - _base.size(),
				[](const base_type::node_allocator_type &nalloc, node_type *node) {
			node->value.construct(allocator_type(nalloc)); //
		});
	}
}

template <typename T, typename Allocator>
constexpr void __forward_list<T, Allocator>::resize(size_type count,
		const value_type &value) noexcept {
	auto target = before_begin();
	if (_base.size() > count) {
		while (count > 0) {
			++target;
			--count;
		}

		while (target != end()) { target = iterator(_base.erase_after(target.__target)); }
	} else if (_base.size() < count) {
		while (target.__target->next != _base.end()) { ++target; }

		_base.expand(target.__target, count - _base.size(),
				[value = &value](const base_type::node_allocator_type &nalloc, node_type *node) {
			node->value.construct(allocator_type(nalloc), *value); //
		});
	}
}

template <typename T, typename Allocator>
constexpr void __forward_list<T, Allocator>::swap(__forward_list &other) noexcept {
	_base.swap(other._base);
}

template <typename Type>
using __pool_forward_list = __forward_list<Type, detail::AllocatorPool<Type>>;

template <typename Type>
using __malloc_forward_list = __forward_list<Type, detail::AllocatorMalloc<Type>>;

template <typename T, typename Allocator>
constexpr inline bool operator==(const __forward_list<T, Allocator> &lhs,
		const __forward_list<T, Allocator> &rhs) {
	if (lhs.size() != rhs.size()) {
		return false;
	}

	auto first1 = lhs.begin();
	auto last1 = lhs.end();
	auto first2 = rhs.begin();
	auto last2 = rhs.end();

	for (; first1 != last1 && first2 != last2; ++first1, ++first2) {
		if (!(*first1 == *first2)) {
			return false;
		}
	}

	return first1 == last1 && first2 == last2;
}

template <typename T, typename Allocator>
constexpr inline auto operator<=>(const __forward_list<T, Allocator> &lhs,
		const __forward_list<T, Allocator> &rhs) {
	return sprt::lexicographical_compare_three_way(lhs.begin(), lhs.end(), rhs.begin(), rhs.end());
}

} // namespace sprt

#endif // RUNTIME_INCLUDE_SPRT_CXX_FORWARD_LIST_H_
